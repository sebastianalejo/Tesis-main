rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Delitos históricos para entrenar / analizar (la app escribe desde el cliente autenticado o vía Functions).
    match /crime_incidents/{docId} {
      allow read, write: if request.auth != null;
    }

    // Artefacto ML troceado — solo las Cloud Functions (Admin SDK) escriben; clientes no acceden.
    match /ml_model_parts/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
