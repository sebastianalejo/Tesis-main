# Copia a frontend/.env.local (no subir a git).
# Alternativa: frontend/public/firebase-config.json (ver firebase-config.example.json); sin VITE_*.
# Para producción: `npm run build` debe ver variables o el JSON en public/.
# Opcional — Google Maps (si no usas mapsApiKey en firebase-config.json):
# VITE_GOOGLE_MAPS_API_KEY=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL base de Cloud Functions (sin / final). Ejemplo producción:
# https://us-central1-TU_PROJECT.cloudfunctions.net
VITE_FIREBASE_FUNCTIONS_ORIGIN=
